{
  "name": "daytona-agentic-workflows",
  "version": "0.1.0",
  "private": true,
  "description": "MVP: non-technical users run agentic work in Daytona sandboxes.",
  "packageManager": "pnpm@10.7.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "dev": "pnpm -r --parallel dev",
    "dev:server": "pnpm --filter @app/server dev",
    "dev:web": "pnpm --filter @app/web dev"
  }
}
