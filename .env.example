# =============================================================================
# Environment contract — copy to `.env` and fill in. Names are FROZEN: add a
# variable here in the same PR that introduces its use (see docs/code-contract.md
# §7). Secrets are read only by apps/server and never reach the browser.
# =============================================================================

# ---- Control-plane server (apps/server) ----
SERVER_PORT=8080
NODE_ENV=development
# Public origin of the web app, for CORS.
WEB_ORIGIN=http://localhost:5173
# Origin browsers use to reach this server (desktop preview iframe). Defaults to http://localhost:SERVER_PORT.
# SERVER_PUBLIC_URL=http://localhost:8080

# ---- Database (Postgres) ----
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Full URL the server uses (matches the values above for docker compose).
DATABASE_URL=postgresql://app:app@postgres:5432/app

# ---- Object storage ----
# 'fs' for MVP (local volume); switch to 'minio'/'s3' later without code changes.
STORAGE_DRIVER=fs
STORAGE_FS_ROOT=/data/storage
# Used only when STORAGE_DRIVER=minio (compose ships a MinIO service, off by default).
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345
MINIO_BUCKET=artifacts

# ---- Daytona ----
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
# Snapshot name is required for workspace creation.
DAYTONA_SNAPSHOT=
# Pinned base snapshot digest is recommended for reproducibility, but optional locally.
DAYTONA_SNAPSHOT_DIGEST=

# ---- Model auth ----
# The only auth path: an OpenAI API key. Set here to seed every new sandbox, or
# leave blank and add a per-workspace key in the web app under Settings.
OPENAI_API_KEY=

# ---- Secrets at rest ----
# 32-byte key (base64) used to encrypt the OpenAI API key stored on workspaces.
# Generate: `openssl rand -base64 32`
AUTH_ENCRYPTION_KEY=

# ---- Web (apps/web, Vite — only VITE_* are exposed to the browser) ----
VITE_API_BASE=http://localhost:8080/api
VITE_WS_URL=ws://localhost:8080/ws
